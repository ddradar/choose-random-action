{
  "name": "choose-random-action",
  "version": "4.1.0",
  "private": true,
  "description": "Choose one randomly from multiple user inputs",
  "keywords": [
    "actions",
    "github-actions",
    "random"
  ],
  "license": "MIT",
  "author": "Nogic <24802730+nogic1008@users.noreply.github.com>",
  "repository": "https://github.com/ddradar/choose-random-action",
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "node --experimental-strip-types build.mts",
    "fix": "run-p fix:*",
    "fix:oxlint": "oxlint --type-aware --fix",
    "fix:oxfmt": "oxfmt",
    "lint": "run-p lint:*",
    "lint:oxlint": "oxlint --type-aware",
    "lint:oxfmt": "oxfmt --check",
    "prepare": "husky",
    "test": "node --test --experimental-strip-types --experimental-test-module-mocks"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.12.0",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,mjs,ts,mts}": [
      "oxlint --type-aware --fix",
      "oxfmt"
    ],
    "*.{json,md,yml}": "oxfmt"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.11.0"
}
